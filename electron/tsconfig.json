{
    "compilerOptions": {
        "module": "commonjs",
        "target": "es2020",
        "outDir": "dist",
        "sourceMap": true,
        "strict": true,
        "moduleResolution": "node",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "types": [
            "node",
            "better-sqlite3"
        ]
    },
    "include": [
        "**/*",
        "types.d.ts"
    ]
}